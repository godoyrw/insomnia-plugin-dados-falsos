  "scripts": {
    "build": "tsc && npm run copy-package",
    "copy-package": "cp package.json dist/insomnia-plugin-dados-falsos/package.json",
    "dev": "tsc --watch",
    "test": "tsc test/quality.ts --outDir dist && node dist/quality.js",
    "test:watch": "tsc test/quality.ts --outDir dist --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "insomnia": {
    "name": "Dados Falsos",
    "displayName": "Dados Falsos",
    "description": "Plugin Insomnia para gerar dados falsos realistas em português para testes de APIs brasileiras. Suporta 60+ template tags incluindo CPF, CNPJ, nomes, endereços, emails, telefones, UUIDs, JWTs e muito mais.",
    "version": "1.0.0",
    "category": "data-generation",
