{
  "name": "insomnia-plugin-dados-falsos",
  "version": "1.4.0",
  "description": "Gere dados sintéticos brasileiros com algoritmos oficiais (CPF, CNPJ, CNH, CNS, PIS, RG, UUID e muito mais) diretamente nas Template Tags do Insomnia.",
  "sideEffects": false,
  "main": "dist/insomnia-plugin-dados-falsos/src/main.js",
  "exports": {
    ".": "./dist/insomnia-plugin-dados-falsos/src/main.js"
  },
  "author": "Roberto Godoy <godoyrw@github.com>",
