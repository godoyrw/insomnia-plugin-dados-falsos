      "url": "https://github.com/godoyrw"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godoyrw/insomnia-plugin-dados-falsos.git"
  },
  "homepage": "https://github.com/godoyrw/insomnia-plugin-dados-falsos#readme",
  "bugs": {
    "url": "https://github.com/godoyrw/insomnia-plugin-dados-falsos/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/godoyrw"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "insomnia",
    "insomnia-plugin",
    "insomnia-template-tag",
    "plugin",
    "dados-falsos",
    "fake-data",
    "mock-data",
