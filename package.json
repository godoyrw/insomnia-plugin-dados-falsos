  "files": [
    "dist/insomnia-plugin-dados-falsos",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run test",
    "clean": "rm -rf dist && find src test -name '*.js' -delete -o -name '*.d.ts' -delete",
    "prebuild": "npm run clean",
    "build": "npm run clean && npx tsc",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "npm run build && node dist/insomnia-plugin-dados-falsos/test/generators.test.js",
    "test:watch": "npm run build && tsc test/generators.test.ts --outDir dist/insomnia-plugin-dados-falsos --watch",
    "test:stress": "npm run build && bash -c 'success=0; fail=0; for i in {1..100}; do if npm test > /tmp/test-stress.log 2>&1; then ((success++)); else ((fail++)); echo \"❌ Falha na execução $i\"; fi; done; echo \"✅ Sucessos: $success\"; echo \"❌ Falhas: $fail\"; exit $fail'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18",
    "insomnia": ">=2021.7.0"
  },
  "insomnia": {
    "name": "Dados Falsos",
    "displayName": "Dados Falsos",
    "description": "Plugin Insomnia para gerar dados falsos realistas em português para testes de APIs brasileiras. Suporta 76 template tags incluindo CPF, CNPJ, CNH, RG, CNS, PIS, placas veiculares, nomes, endereços, emails, telefones, UUIDs, JWTs e muito mais.",
    "version": "1.4.0",
    "category": "data-generation",
    "tags": [
      "dados-falsos",
      "mock-data",
      "test-data",
      "fake-data",
      "brasil",
      "cpf",
      "cnpj",
      "generator"
    ]
  }
}