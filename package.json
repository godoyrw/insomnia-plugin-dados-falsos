{
  "name": "insomnia-plugin-dados-falsos",
  "version": "1.3.1",
  "description": "Plugin Insomnia para gerar Dados Falsos realistas para testes de APIs brasileiras",
  "main": "dist/insomnia-plugin-dados-falsos/src/main.js",
  "exports": {
    ".": "./dist/insomnia-plugin-dados-falsos/src/main.js"
  },
  "author": "godoyrw",
  "maintainers": [
    {
      "name": "Roberto Godoy",
      "email": "godoyrw@github.com",
      "url": "https://github.com/godoyrw"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/godoyrw/insomnia-plugin-dados-falsos.git"
  },
  "homepage": "https://github.com/godoyrw/insomnia-plugin-dados-falsos#readme",
  "bugs": {
    "url": "https://github.com/godoyrw/insomnia-plugin-dados-falsos/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/godoyrw"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "insomnia",
    "insomnia-plugin",
    "plugin",
    "dados-falsos",
    "fake-data",
    "mock-data",
    "test-data",
    "faker",
    "faker-br",
    "brasil",
    "brazilian",
    "cpf",
    "cpf-generator",
    "cnpj",
    "cnpj-generator",
    "rg",
    "cnh",
    "endereco",
    "telefone",
    "email",
    "uuid",
    "jwt",
    "api-key",
    "pix",
    "boleto",
    "api-testing",
    "rest",
    "graphql",
    "typescript",
    "qa",
    "testing",
    "ecommerce"
  ],
  "files": [
    "dist/insomnia-plugin-dados-falsos",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist && find src test -name '*.js' -delete -o -name '*.d.ts' -delete",
    "copy-package": "mkdir -p dist/insomnia-plugin-dados-falsos && cp package.json dist/insomnia-plugin-dados-falsos/package.json",
    "prebuild": "npm run clean",
    "build": "npm run clean && npx tsc",
    "dev": "tsc --watch",
    "test": "tsc test/generators.test.ts --outDir dist/insomnia-plugin-dados-falsos && node dist/insomnia-plugin-dados-falsos/test/generators.test.js",
    "test:watch": "tsc test/generators.test.ts --outDir dist/insomnia-plugin-dados-falsos --watch",
    "test:stress": "bash -c 'success=0; fail=0; for i in {1..100}; do if npm test > /tmp/test-stress.log 2>&1; then ((success++)); else ((fail++)); echo \"❌ Falha na execução $i\"; fi; done; echo \"✅ Sucessos: $success\"; echo \"❌ Falhas: $fail\"; exit $fail'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18",
    "insomnia": ">=2021.7.0"
  },
  "insomnia": {
    "name": "Dados Falsos",
    "displayName": "Dados Falsos",
    "description": "Plugin Insomnia para gerar dados falsos realistas em português para testes de APIs brasileiras. Suporta mais de 65 template tags incluindo CPF, CNPJ, nomes, endereços, emails, telefones, UUIDs, JWTs e muito mais.",
    "version": "1.3.0",
    "category": "data-generation",
    "tags": [
      "dados-falsos",
      "mock-data",
      "test-data",
      "fake-data",
      "brasil",
      "cpf",
      "cnpj",
      "generator"
    ]
  }
}
